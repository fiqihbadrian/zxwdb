{
  "name": "@fiqihbadrian/zxwdb",
  "version": "1.0.0",
  "description": "Visual Database Designer for MySQL/MariaDB - Design, visualize, and manage your database schema with ease",
  "main": "bin/zxwdb.js",
  "bin": {
    "zxwdb": "./bin/zxwdb.js"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build": "npm run build:frontend && npm run build:backend && npm run build:prepare",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:backend": "node scripts/obfuscate-backend.js",
    "build:prepare": "mkdir -p backend/public && cp -r frontend/dist/* backend/public/"
  },
  "keywords": [
    "database",
    "mysql",
    "mariadb",
    "visual-designer",
    "erd",
    "lrs",
    "schema-designer",
    "database-tool",
    "sql",
    "query-builder"
  ],
  "author": "Fiqih Badrian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fiqihbadrian/zxwdb.git"
  },
  "bugs": {
    "url": "https://github.com/fiqihbadrian/zxwdb/issues"
  },
  "homepage": "https://github.com/fiqihbadrian/zxwdb#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "preferGlobal": true,
  "files": [
    "bin/",
    "backend/",
    "README.md",
    "QUICKSTART.md"
  ],
  "devDependencies": {
    "concurrently": "^8.2.0",
    "javascript-obfuscator": "^5.4.3"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "get-port": "^5.1.1",
    "inquirer": "^8.2.5",
    "open": "^8.4.0"
  }
}
